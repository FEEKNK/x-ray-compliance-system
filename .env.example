# Neon Postgres Database URL

DATABASE_URL=

# Gmail Email Configuration (Nodemailer)
# ใส่ Gmail ที่ใช้ส่งอีเมลแจ้งเตือน
GMAIL_USER=
# ใส่ App Password 16 หลักที่ได้จาก Google (ไม่ใช่รหัสผ่านปกติ)
GMAIL_APP_PASSWORD=

# Email of the supervisor who receives alert notifications
SUPERVISOR_EMAIL=

# URL of the application
APP_URL=https://your-production-url.com
